#!/usr/bin/env bash
# Stop hook: nudge the agent to continue the pipeline if it stops mid-run.
#
# This is a FALLBACK safety net. The primary mechanism is the run-pipeline
# orchestrator skill which runs all stages in one continuous turn.
# This hook catches cases where the agent stops unexpectedly.

set -euo pipefail

# Read stdin for stop_hook_active flag (prevent infinite loops)
INPUT=$(cat)
STOP_ACTIVE=$(echo "$INPUT" | python3 -c "import sys,json; print(json.load(sys.stdin).get('stop_hook_active', False))" 2>/dev/null || echo "false")

if [ "$STOP_ACTIVE" = "True" ] || [ "$STOP_ACTIVE" = "true" ]; then
    # Already continuing from a previous stop hook — don't block again
    exit 0
fi

PROJECT_DIR="${PWD}"

# Quick exit: no .launchcraft/ directory means no pipeline in progress
if [ ! -d "${PROJECT_DIR}/.launchcraft" ]; then
    exit 0
fi

# Check if pipeline artifacts suggest work in progress
# (requirements exist but no launch record = pipeline incomplete)
has_requirements=false
has_launch=false

if [ -d "${PROJECT_DIR}/.launchcraft/requirements" ] && ls "${PROJECT_DIR}/.launchcraft/requirements/"*.md &>/dev/null; then
    has_requirements=true
fi

if [ -d "${PROJECT_DIR}/.launchcraft/launches" ] && ls "${PROJECT_DIR}/.launchcraft/launches/"*.md &>/dev/null; then
    has_launch=true
fi

# If requirements exist but launch doesn't, pipeline is incomplete
if [ "$has_requirements" = true ] && [ "$has_launch" = false ]; then
    cat <<EOF
{
  "decision": "block",
  "reason": "Pipeline is incomplete. Call the Skill tool: Skill(skill='run-pipeline') to continue the pipeline from where it left off. Do NOT output text — CALL THE TOOL."
}
EOF
else
    exit 0
fi
